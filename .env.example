# -----------------------------
# 钉钉 CalDAV 读取探测
# 说明：如果仅有 calendar.dingtalk.com，也可填写该域名
# 脚本会自动尝试 /.well-known/caldav 与 /dav/principals/ 发现流程
# -----------------------------
DINGTALK_CALDAV_BASE_URL=calendar.dingtalk.com
DINGTALK_CALDAV_USERNAME=your_dingtalk_username
DINGTALK_CALDAV_PASSWORD=your_dingtalk_password

# 可选：来源日历选择（多选，CSV）
# 为空表示默认读取该账号下全部可访问日历
DINGTALK_CALDAV_SOURCE_CALENDAR_NAMES=
DINGTALK_CALDAV_SOURCE_CALENDAR_HREFS=
# 兼容旧键（建议不再使用）
DINGTALK_CALDAV_CALENDAR_NAME=
DINGTALK_CALDAV_CALENDAR_HREF=

# 可选：调优参数
DINGTALK_CALDAV_USER_AGENT=calendar-sync-dingtalk-read-probe/0.1
DINGTALK_CALDAV_TIMEOUT_MS=15000
DINGTALK_TEST_RANGE_PAST_DAYS=7
DINGTALK_TEST_RANGE_FUTURE_DAYS=30

# -----------------------------
# iCloud CalDAV 读写探测
# -----------------------------
ICLOUD_CALDAV_BASE_URL=https://caldav.icloud.com
ICLOUD_APPLE_ID=your_apple_id@example.com
ICLOUD_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# 可选：目标写入日历（单选）
# 为空时自动选择第一个可写日历（会跳过“提醒/节假日”等只读倾向日历）
ICLOUD_TARGET_CALENDAR_NAME=
ICLOUD_TARGET_CALENDAR_HREF=

# 可选：调优参数
ICLOUD_CALDAV_USER_AGENT=calendar-sync-icloud-rw-probe/0.1
ICLOUD_CALDAV_TIMEOUT_MS=15000
ICLOUD_TEST_EVENT_DURATION_MINUTES=30
ICLOUD_TEST_UID_PREFIX=calendar-sync-probe
ICLOUD_TEST_DRY_RUN=false
ICLOUD_TEST_KEEP_EVENT=false

# -----------------------------
# 正式同步服务（钉钉 -> iCloud）
# -----------------------------
# 同步状态文件路径
SYNC_STATE_FILE=/home/shiver/projects/calendar-sync/service/data/sync-state.json
# 日志文件路径（JSON 行格式，CLI/UI 可读取）
LOG_FILE=/home/shiver/projects/calendar-sync/service/data/logs/calendar-sync.log
# 日志级别：debug / info / warn / error
LOG_LEVEL=info
# 同步时间窗：过去 N 天 + 未来 N 天
SYNC_PAST_DAYS=7
SYNC_FUTURE_DAYS=180
# 常驻服务定时周期（秒）
SYNC_INTERVAL_SECONDS=300
# 服务心跳周期（秒，最小 5）
HEARTBEAT_INTERVAL_SECONDS=30
# 服务启动后是否立即执行一次同步
SYNC_RUN_ON_STARTUP=true
# 为 true 时只计算不写入 iCloud（生产建议 false）
SYNC_DRY_RUN=false
# 是否启用删除同步（钉钉删除 -> iCloud 删除，生产建议 true）
SYNC_ENABLE_DELETE=true
# 连续 missing 达到阈值后才会进入删除确认
SYNC_DELETE_CONFIRM_RUNS=2
# 删除保护：missing/active 超过该比例则跳过本轮删除
SYNC_DELETE_MAX_RATIO=0.9

# 服务监听地址
HOST=0.0.0.0
PORT=8787
# 可选：手动触发 /api/sync（兼容 /sync）的鉴权 token
SYNC_API_TOKEN=
